{
  "name": "@veritylayer/guard",
  "version": "0.3.1",
  "description": "Fail-closed verify-before-you-act gate for AI agents. Keyless x402 client + Vercel AI SDK adapter. Signed, independently re-verifiable verdicts.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vercel": {
      "types": "./dist/vercel.d.ts",
      "import": "./dist/vercel.js"
    },
    "./payer": {
      "types": "./dist/payer.d.ts",
      "import": "./dist/payer.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node --test \"test/*.test.mjs\""
  },
  "keywords": [
    "ai",
    "agents",
    "guardrail",
    "verification",
    "fact-check",
    "prompt-injection",
    "ai-safety",
    "x402",
    "agent-commerce",
    "vercel-ai-sdk",
    "ai-sdk",
    "signed-receipts",
    "trust",
    "fail-closed",
    "veritylayer"
  ],
  "author": "VerityLayer",
  "license": "MIT",
  "homepage": "https://veritylayer.dev/guard",
  "repository": {
    "type": "git",
    "url": "https://github.com/meloliva14/verity-guard"
  },
  "peerDependencies": {
    "@x402/evm": ">=2",
    "@x402/fetch": ">=2",
    "ai": ">=3",
    "viem": ">=2",
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "@x402/evm": {
      "optional": true
    },
    "@x402/fetch": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "viem": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@x402/evm": "^2.18.0",
    "@x402/fetch": "^2.18.0",
    "typescript": "^5.5.0",
    "viem": "^2.55.2",
    "zod": "^3.23.0"
  }
}
